{
  "name": "supermarket-accounting-system",
  "version": "1.0.0",
  "description": "Complete supermarket accounting information system with Docker support",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "migrate": "node migrations/runner.js",
    "dev": "nodemon server.js",
